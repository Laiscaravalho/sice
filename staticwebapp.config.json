{
  "$schema": "https://aka.ms/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/_next/*", "/images/*", "/*.{png,jpg,gif,ico,svg,webp,woff,woff2,ttf,css,js,json}"]
  },
  "routes": [{ "route": "/*", "serve": "/index.html", "statusCode": 200 }],
  "responseOverrides": { "404": { "rewrite": "/index.html", "statusCode": 200 } },
  "globalHeaders": { "X-Content-Type-Options": "nosniff", "X-Frame-Options": "SAMEORIGIN" }
}
